# Environment variables for the /api/save-result serverless function.
# Set these in the Vercel dashboard (Project → Settings → Environment Variables).
# Do NOT commit real values — this file is only a template.

# Fine-grained GitHub personal access token with "Contents: read & write"
# permission on the fantasy-world-cup repo. Create at:
# https://github.com/settings/tokens?type=beta
GH_TOKEN=github_pat_xxxxxxxx

# The repository to commit edits to, as "owner/name".
GH_REPO=dwb217/fantasy-world-cup

# Shared password that editors must type in the web app to save changes.
EDIT_PASSWORD=change-me

# Optional overrides (defaults shown):
# GH_BRANCH=main
# OVERRIDES_PATH=data/overrides.js
